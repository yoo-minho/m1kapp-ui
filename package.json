{
  "name": "@m1k/ui",
  "version": "0.1.0",
  "description": "Mobile-first app shell UI components for side projects",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "keywords": [
    "react",
    "ui",
    "mobile",
    "app-shell",
    "tailwind",
    "side-project",
    "m1k"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoominho/m1k-ui"
  },
  "homepage": "https://m1k.app"
}
