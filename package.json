{
  "name": "@m1kapp/ui",
  "version": "0.1.17",
  "description": "Mobile-first app shell UI components for side projects",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "mkdir -p .tmp && npx @tailwindcss/cli -i src/styles.css -o .tmp/styles.css --minify && node scripts/embed-css.mjs && tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "demo": "cd demo && npm run dev",
    "demo:build": "cd demo && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "react",
    "ui",
    "mobile",
    "app-shell",
    "tailwind",
    "side-project",
    "m1k"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m1kapp/ui.git"
  },
  "homepage": "https://m1k.app"
}
